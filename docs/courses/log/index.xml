&lt;/colgroup&gt;
&lt;thead&gt;
&lt;tr class=&#34;header&#34;&gt;
&lt;th&gt;Item&lt;/th&gt;
&lt;th&gt;Proporção da nota&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr class=&#34;odd&#34;&gt;
&lt;td&gt;Conteúdo&lt;/td&gt;
&lt;td&gt;70%&lt;/td&gt;
&lt;/tr&gt;
&lt;tr class=&#34;even&#34;&gt;
&lt;td&gt;Relevância da mudanças em discussão&lt;/td&gt;
&lt;td&gt;2 pontos&lt;/td&gt;
&lt;/tr&gt;
&lt;tr class=&#34;odd&#34;&gt;
&lt;td&gt;Pertinência da relação estabelecida entre a GCS e a mudança proposta&lt;/td&gt;
&lt;td&gt;1 ponto&lt;/td&gt;
&lt;/tr&gt;
&lt;tr class=&#34;even&#34;&gt;
&lt;td&gt;Discussão do trade-off logístico relacionando vantagens e desvantagens da mudança para a GCS&lt;/td&gt;
